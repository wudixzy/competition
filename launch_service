#!/bin/bash

export PYTHONPATH=/usr/local/corex/lib64/python3/dist-packages:/usr/local/corex/lib/python3/dist-packages:${PYTHONPATH:-}
export LD_LIBRARY_PATH=/usr/local/corex/lib:/usr/local/corex/lib64:/usr/local/corex-3.2.3/lib:/usr/local/corex-3.2.3/lib64:/usr/local/openmpi/lib:${LD_LIBRARY_PATH:-}
export PATH=/usr/local/corex/bin:/usr/local/corex-3.2.3/bin:/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin:/usr/local/corex/lib64/python3/dist-packages/bin:/usr/local/openmpi/bin:${PATH:-}
export JAVA_HOME=/root/apps/jdk1.8.0_411
export JRE_HOME=/root/apps/jdk1.8.0_411/jre
export JMETER_HOME=/root/apps/apache-jmeter-5.6.3
export CLASSPATH=.:/root/apps/jdk1.8.0_411/lib/dt.jar:/root/apps/jdk1.8.0_411/lib/tools.jar:/root/apps/apache-jmeter-5.6.3/lib/ext/ApacheJMeter_core.jar:/root/apps/apache-jmeter-5.6.3/lib/jorphan.jar:/root/apps/apache-jmeter-5.6.3/lib/logkit-2.0.jar:
export PATH=/root/apps/apache-jmeter-5.6.3/bin:/root/apps/jdk1.8.0_411/bin:/usr/local/corex/bin:/usr/local/corex-3.2.3/bin:/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin:/usr/local/corex/lib64/python3/dist-packages/bin:/usr/local/openmpi/bin:${PATH:-}
/iluvatar/welcome.sh

date
cat /proc/cpuinfo | tail -n 50
ixsmi
if [ "${BI100_UNSET_CUDA_VISIBLE_DEVICES:-1}" = "1" ]; then
    unset CUDA_VISIBLE_DEVICES
fi
date

DEFAULT_HOST="0.0.0.0"
DEFAULT_PORT="80"
DEFAULT_SERVED_MODEL_NAME="llm"
DEFAULT_MODEL_PATH="/model"
DEFAULT_MAX_MODEL_LEN="100000"
DEFAULT_TENSOR_PARALLEL_SIZE="4"
DEFAULT_GPU_MEMORY_UTILIZATION="0.90"
DEFAULT_MAX_NUM_SEQS="1"
DEFAULT_MAX_NUM_BATCHED_TOKENS="8192"
DEFAULT_MAX_SEQ_LEN_TO_CAPTURE="32768"
DEFAULT_NUM_GPU_BLOCKS_OVERRIDE=""
DEFAULT_DTYPE=""
DEFAULT_ENFORCE_EAGER="false"
DEFAULT_DISABLE_LOG_REQUESTS="true"
DEFAULT_DISABLE_FRONTEND_MULTIPROCESSING="true"
DEFAULT_CHUNKED_PREFILL="true"
DEFAULT_PREFIX_CACHING="true"
DEFAULT_AUTO_TOOL_CHOICE="true"
DEFAULT_TOOL_CALL_PARSER="qwen3_coder"
DEFAULT_REASONING_PARSER="qwen3"

HOST_VAL=${HOST:-$DEFAULT_HOST}
PORT_VAL=${PORT:-$DEFAULT_PORT}
SERVED_MODEL_NAME_VAL=${SERVED_MODEL_NAME:-$DEFAULT_SERVED_MODEL_NAME}
MODEL_PATH_VAL=${MODEL_PATH:-$DEFAULT_MODEL_PATH}
MAX_MODEL_LEN_VAL=${MAX_MODEL_LEN:-$DEFAULT_MAX_MODEL_LEN}
TENSOR_PARALLEL_SIZE_VAL=${TENSOR_PARALLEL_SIZE:-$DEFAULT_TENSOR_PARALLEL_SIZE}
GPU_MEMORY_UTILIZATION_VAL=${GPU_MEMORY_UTILIZATION:-$DEFAULT_GPU_MEMORY_UTILIZATION}
MAX_NUM_SEQS_VAL=${MAX_NUM_SEQS:-$DEFAULT_MAX_NUM_SEQS}
MAX_NUM_BATCHED_TOKENS_VAL=${MAX_NUM_BATCHED_TOKENS:-$DEFAULT_MAX_NUM_BATCHED_TOKENS}
MAX_SEQ_LEN_TO_CAPTURE_VAL=${MAX_SEQ_LEN_TO_CAPTURE:-$DEFAULT_MAX_SEQ_LEN_TO_CAPTURE}
NUM_GPU_BLOCKS_OVERRIDE_VAL=${NUM_GPU_BLOCKS_OVERRIDE:-$DEFAULT_NUM_GPU_BLOCKS_OVERRIDE}
DTYPE_VAL=${DTYPE:-$DEFAULT_DTYPE}
INCLUDE_ENFORCE_EAGER_FLAG=${ENFORCE_EAGER:-$DEFAULT_ENFORCE_EAGER}
INCLUDE_DISABLE_LOG_REQUESTS_FLAG=${DISABLE_LOG_REQUESTS:-$DEFAULT_DISABLE_LOG_REQUESTS}
INCLUDE_DISABLE_FRONTEND_MULTIPROCESSING_FLAG=${DISABLE_FRONTEND_MULTIPROCESSING:-$DEFAULT_DISABLE_FRONTEND_MULTIPROCESSING}
INCLUDE_CHUNKED_PREFILL_FLAG=${CHUNKED_PREFILL:-$DEFAULT_CHUNKED_PREFILL}
INCLUDE_PREFIX_CACHING_FLAG=${PREFIX_CACHING:-$DEFAULT_PREFIX_CACHING}
INCLUDE_AUTO_TOOL_CHOICE_FLAG=${AUTO_TOOL_CHOICE:-$DEFAULT_AUTO_TOOL_CHOICE}
TOOL_CALL_PARSER_VAL=${TOOL_CALL_PARSER:-$DEFAULT_TOOL_CALL_PARSER}
REASONING_PARSER_VAL=${REASONING_PARSER:-$DEFAULT_REASONING_PARSER}
export VLLM_ENGINE_ITERATION_TIMEOUT_S=${VLLM_ENGINE_ITERATION_TIMEOUT_S:-3600}

echo "[BI100] model=${MODEL_PATH_VAL} tp=${TENSOR_PARALLEL_SIZE_VAL} max_len=${MAX_MODEL_LEN_VAL} max_seqs=${MAX_NUM_SEQS_VAL} batch_tokens=${MAX_NUM_BATCHED_TOKENS_VAL}"

CMD_ARGS=()
CMD_ARGS+=(--host "$HOST_VAL")
CMD_ARGS+=(--port "$PORT_VAL")

if [[ "$INCLUDE_ENFORCE_EAGER_FLAG" != "false" && "$INCLUDE_ENFORCE_EAGER_FLAG" != "0" ]]; then
    CMD_ARGS+=(--enforce-eager)
fi
if [[ "$INCLUDE_DISABLE_LOG_REQUESTS_FLAG" != "false" && "$INCLUDE_DISABLE_LOG_REQUESTS_FLAG" != "0" ]]; then
    CMD_ARGS+=(--disable-log-requests)
fi
if [[ "$INCLUDE_DISABLE_FRONTEND_MULTIPROCESSING_FLAG" != "false" && "$INCLUDE_DISABLE_FRONTEND_MULTIPROCESSING_FLAG" != "0" ]]; then
    CMD_ARGS+=(--disable-frontend-multiprocessing)
fi
if [[ "$INCLUDE_CHUNKED_PREFILL_FLAG" != "false" && "$INCLUDE_CHUNKED_PREFILL_FLAG" != "0" ]]; then
    CMD_ARGS+=(--enable-chunked-prefill)
fi
if [[ "$INCLUDE_PREFIX_CACHING_FLAG" != "false" && "$INCLUDE_PREFIX_CACHING_FLAG" != "0" ]]; then
    CMD_ARGS+=(--enable-prefix-caching)
fi
if [[ "$INCLUDE_AUTO_TOOL_CHOICE_FLAG" != "false" && "$INCLUDE_AUTO_TOOL_CHOICE_FLAG" != "0" ]]; then
    CMD_ARGS+=(--enable-auto-tool-choice)
fi

CMD_ARGS+=(--served-model-name "$SERVED_MODEL_NAME_VAL")
CMD_ARGS+=(--model "$MODEL_PATH_VAL")
CMD_ARGS+=(--max-model-len "$MAX_MODEL_LEN_VAL")
CMD_ARGS+=(--tensor-parallel-size "$TENSOR_PARALLEL_SIZE_VAL")
CMD_ARGS+=(--gpu-memory-utilization "$GPU_MEMORY_UTILIZATION_VAL")
CMD_ARGS+=(--max-num-seqs "$MAX_NUM_SEQS_VAL")
CMD_ARGS+=(--max-num-batched-tokens "$MAX_NUM_BATCHED_TOKENS_VAL")
CMD_ARGS+=(--max-seq-len-to-capture "$MAX_SEQ_LEN_TO_CAPTURE_VAL")
if [[ -n "$NUM_GPU_BLOCKS_OVERRIDE_VAL" ]]; then
    CMD_ARGS+=(--num-gpu-blocks-override "$NUM_GPU_BLOCKS_OVERRIDE_VAL")
fi
if [[ -n "$DTYPE_VAL" ]]; then
    CMD_ARGS+=(--dtype "$DTYPE_VAL")
fi
CMD_ARGS+=(--tool-call-parser "$TOOL_CALL_PARSER_VAL")
CMD_ARGS+=(--reasoning-parser "$REASONING_PARSER_VAL")
CMD_ARGS+=(--trust-remote-code)

echo "--------------------------------------------------"
echo "Starting VLLM OpenAI API Server..."
echo "Using effective arguments:"
echo "  Host (--host):                  $HOST_VAL"
echo "  Port (--port):                  $PORT_VAL"
echo "  Enforce Eager (--enforce-eager):" $([[ "$INCLUDE_ENFORCE_EAGER_FLAG" != "false" && "$INCLUDE_ENFORCE_EAGER_FLAG" != "0" ]] && echo "Enabled" || echo "Disabled (Env: ENFORCE_EAGER=$ENFORCE_EAGER)")
echo "  Disable Log Req (--disable-log-requests):" $([[ "$INCLUDE_DISABLE_LOG_REQUESTS_FLAG" != "false" && "$INCLUDE_DISABLE_LOG_REQUESTS_FLAG" != "0" ]] && echo "Enabled" || echo "Disabled (Env: DISABLE_LOG_REQUESTS=$DISABLE_LOG_REQUESTS)")
echo "  Served Model Name (--served-model-name): $SERVED_MODEL_NAME_VAL"
echo "  Model Path (--model):           $MODEL_PATH_VAL"
echo "  Max Model Length (--max-model-len): $MAX_MODEL_LEN_VAL"
echo "  Tensor Parallel Size (--tensor-parallel-size): $TENSOR_PARALLEL_SIZE_VAL"
echo "  GPU Memory Utilization (--gpu-memory-utilization): $GPU_MEMORY_UTILIZATION_VAL"
echo "  Max Num Seqs (--max-num-seqs):  $MAX_NUM_SEQS_VAL"
echo "  Max Num Batched Tokens (--max-num-batched-tokens): $MAX_NUM_BATCHED_TOKENS_VAL"
echo "  Max Seq Len To Capture (--max-seq-len-to-capture): $MAX_SEQ_LEN_TO_CAPTURE_VAL"
echo "  Num GPU Blocks Override (--num-gpu-blocks-override): ${NUM_GPU_BLOCKS_OVERRIDE_VAL:-auto}"
echo "  DType (--dtype):                 ${DTYPE_VAL:-auto}"
echo "  Tool Parser (--tool-call-parser): $TOOL_CALL_PARSER_VAL"
echo "  Reasoning Parser (--reasoning-parser): $REASONING_PARSER_VAL"
echo "--------------------------------------------------"
echo "Full cmd:"
echo "python3 -m vllm.entrypoints.openai.api_server ${CMD_ARGS[*]}"
echo "--------------------------------------------------"

python3 -m vllm.entrypoints.openai.api_server "${CMD_ARGS[@]}"
